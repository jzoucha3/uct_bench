# UCT-Benchmark Environment Configuration
# Copy this file to .env and fill in your credentials
# IMPORTANT: Never commit .env to version control

# =============================================================================
# API Credentials
# =============================================================================

# Unified Data Library (UDL) API Token
# Obtain from: https://unifieddatalibrary.com
# Format: Base64-encoded credentials
UDL_TOKEN=your_base64_encoded_udl_token_here

# Optional: raw UDL username/password (only used if UDL_TOKEN is not set)
# The demo runner can generate UDL_TOKEN from these values at runtime.
# UDL_USERNAME=your_udl_username_here
# UDL_PASSWORD=your_udl_password_here

# European Space Agency (ESA) API Token
# Obtain from: https://discosweb.esoc.esa.int
ESA_TOKEN=your_esa_api_token_here

# =============================================================================
# Orekit Configuration
# =============================================================================

# Path to Orekit data directory
# Download from: https://gitlab.orekit.org/orekit/orekit-data
OREKIT_DATA_PATH=./orekit-data-main

# =============================================================================
# Database Configuration
# =============================================================================

# Database Backend: 'duckdb' (default) or 'postgres'/'supabase'
# - 'duckdb': Local file-based database (recommended for local development)
# - 'postgres' or 'supabase': Remote PostgreSQL database (shared data, production use)
DATABASE_BACKEND=duckdb

# DuckDB Configuration (used when DATABASE_BACKEND=duckdb)
# Path to the DuckDB database file (optional, has sensible default)
# DATABASE_PATH=./data/database/uct_benchmark.duckdb

# =============================================================================
# PostgreSQL/Supabase Configuration (used when DATABASE_BACKEND=postgres)
# =============================================================================
#
# IMPORTANT: If DATABASE_URL is NOT set, a READ-ONLY connection to the shared
# UCT Benchmark Supabase instance is used automatically. This allows you to:
# - Browse and download existing datasets
# - Run benchmarks against shared data
#
# For FULL ACCESS (create datasets, modify data), you need to set DATABASE_URL:
#
# Option 1: Use the shared Supabase with write access (contact admin for password)
# DATABASE_URL=postgresql://postgres.csuqtcizjfsmkoeevyau:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres
#
# Option 2: Use your own Supabase project
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres
#
# Option 3: Use a local PostgreSQL server
# DATABASE_URL=postgresql://postgres:password@localhost:5432/uct_benchmark

# Connection Pool Settings (PostgreSQL only)
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# =============================================================================
# Test Database Configuration (Optional)
# =============================================================================

# Backend for tests: 'duckdb' (default) or 'postgres'
# TEST_DATABASE_BACKEND=duckdb

# PostgreSQL URL for tests (used when TEST_DATABASE_BACKEND=postgres)
# TEST_DATABASE_URL=postgresql://postgres:testpassword@localhost:5433/uct_benchmark_test

# =============================================================================
# Application Settings (Optional)
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Backend API port
# API_PORT=8000
